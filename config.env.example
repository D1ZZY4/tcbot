## -- Remove this line after filling in your values --

BOT_TOKEN = ""
## Your Telegram bot token. Get it from @BotFather on Telegram.
## eg: "7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

OWNER_ID = ""
## Your Telegram user ID (numeric). Get it from @userinfobot or @getidsbot.
## This user has full owner-level access to the bot.
## eg: "7146954165"

MONGODB_URI = ""
## Your MongoDB connection string. Get it from your MongoDB provider (Atlas, etc.).
## eg: "mongodb+srv://username:password@cluster.mongodb.net/?appName=MyApp"

DB_NAME = ""
## The MongoDB database name to use. Created automatically if it does not exist.
## eg: "tcbot"

REDIS_URL = ""
## (Optional) Redis connection URL for distributed caching across bot restarts.
## When set, role / connection / groups / owner caches use Redis as L2 storage.
## hiredis C extension is auto-used when installed (already in pyproject.toml).
## eg: "redis://localhost:6379" or "redis://:password@host:6379/0"
## Leave empty to use in-memory caching only (single-process default).

COMMUNITY_NAME = ""
## Display name of your federation / community. Used in bot messages and log headers.
## eg: "TCF - Transsion Core Federation"

PREFIXES = ["/", "!", "."]
## List of command prefixes the bot will recognize.
## Must be a Python-style list. Defaults to ["/"] if not set.
## eg: ["/", "!"] or ["/", ".", "!"]

PORT = "5000"
## Port for the Flask keep-alive / health-check server.
## Set to a number between 1 and 65535 to use a specific port.
## "auto" or any invalid/empty value silently defaults to 5000.
## Set to the port your hosting platform expects (e.g. 8080 on Replit).
## eg: "5000" or "8080"

MAIN_GROUP = ""
## Chat ID of your main community group or forum (supergroup).
## Must be a negative number.
## eg: "-1001234567890"

MAIN_CHANNEL = ""
## (Optional) Chat ID of your main community announcement channel.
## Used as a reference in some log messages.
## Must be a negative number.
## eg: "-1001234567890"

EXTEND_GROUP = "" # (Optional)
## Chat ID of a secondary / staff-only group.
## When set, the greeting handler will also watch this group alongside MAIN_GROUP.
## Must be a negative number.
## eg: "-1001234567890"

PROOFS = ""
## Where ban proof media is uploaded to after a /tcban is issued.
## Use a standalone channel/group chat ID, or a forum thread as chat_id/thread_id.
## eg: "-1001234567890" or "-1001234567890/67"

LOGS = ""
## Where ban / unban / appeal / admin action log messages are sent.
## Use a standalone channel/group chat ID, or a forum thread as chat_id/thread_id.
## eg: "-1001234567890" or "-1001234567890/42"

LOGS_ERRORS = "" # (Optional)
## Separate destination for error-level log messages.
## Same format as LOGS. If empty, errors are sent to the same place as LOGS.
## eg: "-1001234567890/279"

APPEALS = ""
## Where submitted appeal messages are forwarded for record-keeping.
## Use a standalone channel/group chat ID, or a forum thread as chat_id/thread_id.
## eg: "-1001234567890/12"

APPEAL_DISCUSSION_TOPIC = ""
## Thread ID (integer only, not chat_id/thread_id) inside MAIN_GROUP where
## appeal review cards are posted. Staff vote here with Approve / Reject buttons.
## The chat is always MAIN_GROUP - only supply the thread number.
## eg: 11

PROOF_TIMEOUT_SECONDS = 100
## Intended proof-upload timeout in seconds for /tcban.
## Parsed and stored in cfg.proof_timeout but not currently enforced; conversations
## end via command-fallback only (PTB job-queue / conversation_timeout not used).
## Reserved for future wiring when the [job-queue] extra is adopted.
## Default: 100 seconds.

APPEAL_TIMEOUT_SECONDS = 600
## Intended appeal conversation timeout in seconds.
## Parsed and stored in cfg.appeal_timeout but not currently enforced; conversations
## end via command-fallback only (PTB job-queue / conversation_timeout not used).
## Reserved for future wiring when the [job-queue] extra is adopted.
## Default: 600 seconds.

ALBUM_DEBOUNCE_SECONDS = 2
## How long (in seconds) to buffer incoming album messages before processing.
## Telegram sends album items as separate messages; this window lets them all
## arrive before the ban executor runs.
## Default: 2 seconds.

WARN_LIMIT = 3
## Per-group warning threshold that triggers an automatic federation ban.
## When a user's warn count in a single group reaches exactly this value,
## they are federation-banned and their warns in that group are cleared.
## Uses exact equality (==) so concurrent increments cannot double-fire the ban.
## Minimum 1. Default 3.

FED_WARN_LIMIT = 0
## Federation-wide warn threshold that triggers an automatic federation ban.
## When a user accumulates this many warnings across ALL connected groups combined,
## they are federation-banned even if no single group reached WARN_LIMIT.
## Set to 0 (default) to disable cross-group enforcement and rely only on the
## per-group WARN_LIMIT threshold. A value of 5-6 is a reasonable starting point
## for a 10+ group federation where WARN_LIMIT is 3.

LOG_LEVEL = INFO
## Log verbosity for the bot's own logger.
## Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
## Use DEBUG during development to see verbose internal output.
## Default: INFO

MODULES_LOAD = ""
## (Optional) Comma-separated list of module filenames to load exclusively (whitelist).
## When set, ONLY these modules are loaded - everything else is skipped.
## Leave empty to load all available modules.
## eg: "banning,appeals,admins"

MODULES_NO_LOAD = ""
## (Optional) Comma-separated list of module filenames to skip entirely (blacklist).
## These modules will not be loaded. Has no effect when MODULES_LOAD is set.
## eg: "maintenance,broadcasting"

WARN_EXPIRY_DAYS = 0
## (Optional) Number of days after which warn_count records are deleted.
## 0 = disabled (warn counts never expire automatically).
## When > 0, APScheduler runs a daily job to clean up old warn_counts entries.
## eg: 30 (expire warns after 30 days) or 90 (expire after 3 months)

WEBHOOK_URL = ""
## (Optional) Public base URL for the webhook endpoint.
## When set, the bot registers set_webhook() with Telegram and receives updates
## via POST /webhook instead of long-polling.
## On Replit this is auto-detected from REPLIT_DEV_DOMAIN; no manual value needed.
## For VPS or other hosting, set this to your HTTPS domain.
## Leave empty for local development; the bot falls back to long-polling.
## eg: "https://mybotdomain.example.com"

WEBHOOK_SECRET = ""
## (Optional) Secret token sent by Telegram in X-Telegram-Bot-Api-Secret-Token.
## When set, this value is used as-is. When empty, a random 64-char hex token is
## generated at startup (changes every restart; safe because set_webhook is always
## called with the current token).
## eg: "my-very-long-random-secret-token-here"

COMMUNITY_CHANNEL_URL = ""
## (Optional) Public URL of the main community channel shown in the Additional Links menu.
## When empty, the "Main Channel" button is not shown.
## eg: "https://t.me/TranssionCoreFederation"

COMMUNITY_GROUP_URL = ""
## (Optional) Public URL of the main community discussion group.
## When empty, the "Discussion Group" button is not shown.
## eg: "https://t.me/TranssionCoreFederationGroup"

COMMUNITY_LOGS_URL = ""
## (Optional) Public URL of the logs channel.
## When empty, the "Logs Channel" button is not shown.
## eg: "https://t.me/TranssionCoreFederationLogs"

COMMUNITY_EXEC_URL = ""
## (Optional) Public URL or invite link of the exec/staff group.
## When empty, the "Exec Group" button is not shown.
## eg: "https://t.me/+A105pfnCvkhiZWM1"

COMMUNITY_TRAVEL_URL = ""
## (Optional) Public URL or invite link of the TRAVEL community group.
## When empty, the "TRAVEL" button is not shown.
## eg: "https://t.me/+S2C_ppFvHlAwMzNl"

AI_API_URL = "https://api.kilo.ai/api/gateway"
## (Optional) Base URL of the LLM API used by AI moderation.
## Kilo AI Gateway exposes an OpenAI-compatible API (POST /chat/completions) at this
## base URL, not an Anthropic-style Messages API — ai_client.py should use the OpenAI
## chat-completions request/response shape.
## Leave empty to disable AI moderation entirely (fail-open, WARNING logged at startup).

AI_API_KEY = ""
## (Optional) API key for the LLM gateway above. NEVER put the real value here.
## Store it as a Replit Secret (see Secrets tool in the workspace) and let the bot
## read it from the environment - this file only documents which variable name is expected.

AI_MODEL = "nvidia/nemotron-3-ultra-550b-a55b:free"
## (Optional) Model ID sent in the chat-completions request, in "provider/model" format.
## Default is NVIDIA Nemotron 3 Ultra's free tier on the Kilo AI Gateway (550B total /
## 55B active params, MoE). Change to any other model ID supported by your gateway.

AI_VISION_MODEL = "stepfun/step-3.7-flash:free"
## (Optional) Vision-capable model ID used only for profile pictures and photos/videos sent
## in chat (separate from AI_MODEL, which stays text-only). Leave empty to disable just the
## vision features - text moderation keeps working normally.

AI_PFP_SCAN_INTERVAL_HOURS = "24"
## (Optional) How often the scheduled job re-scans member profile pictures/nicknames.

AI_VISION_MAX_VIDEO_MB = "20"
AI_VISION_MAX_VIDEO_SECONDS = "60"
## (Optional) Videos larger/longer than these limits skip vision analysis and fall back to
## text/caption-only evaluation, to control API cost and avoid timeouts.
